{
  "name": "perpetualbrain",
  "private": true,
  "version": "0.1.0",
  "productName": "PerpetualBrain",
  "description": "A local-first AI second brain and Codex command center for project memory, prompts, decisions, and reusable context.",
  "author": "sebastien lato",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "electron:compile": "rm -rf dist-electron && tsc -p tsconfig.electron.json && cp electron/preload.cjs dist-electron/electron/preload.cjs",
    "electron:dev": "concurrently -k -n web,electron -c green,magenta \"npm:dev:web\" \"wait-on http://localhost:5173 && npm run electron:compile && electron .\"",
    "electron:pack": "npm run build && npm run electron:compile && electron-builder --dir",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "dist:mac": "npm run build && npm run electron:compile && electron-builder --mac",
    "icons:generate": "python3 scripts/generate-icons.py",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "oxlint --ignore-pattern dist --ignore-pattern dist-electron --ignore-pattern release",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.latodev.perpetualbrain",
    "productName": "PerpetualBrain",
    "copyright": "Copyright © 2026 sebastien lato",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "brain",
        "to": "brain-seed"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
